{
  "schema_version": "1.0",
  "brand": "Nykaa",
  "rules": [
    {
      "id": "GR-001",
      "name": "High CX Risk Score",
      "category": "customer_interaction",
      "severity": "block",
      "derived_from": "Crisis Blindspot",
      "condition": {
        "metric": "cx_risk_score",
        "operator": "gt",
        "threshold": 0.18
      },
      "reason": "CX risk score exceeds acceptable threshold for customer interactions."
    },
    {
      "id": "GR-002",
      "name": "Ad Spend With High CX Risk",
      "category": "campaign_launch",
      "severity": "warn",
      "derived_from": "Crisis Blindspot",
      "condition": {
        "metric": "ads.status",
        "operator": "eq",
        "threshold": "active"
      },
      "reason": "High advertising spend while cx_risk_score is elevated."
    },
    {
      "id": "GR-003",
      "name": "Underclaimed ROAS Detected",
      "category": "campaign_launch",
      "severity": "warn",
      "derived_from": "ROAS Underclaim",
      "condition": {
        "metric": "platform_roas_to_true_roas_ratio",
        "operator": "lt",
        "threshold": 1
      },
      "reason": "Platform ROAS significantly lower than true ROAS, indicating possible underclaim."
    },
    {
      "id": "GR-004",
      "name": "Low Customer Rating Trigger",
      "category": "customer_interaction",
      "severity": "block",
      "derived_from": "Crisis Blindspot",
      "condition": {
        "metric": "customer.avg_rating",
        "operator": "lt",
        "threshold": 3
      },
      "reason": "Low average customer rating might indicate product problems."
    },
    {
      "id": "GR-005",
      "name": "Support Tickets Surge",
      "category": "customer_interaction",
      "severity": "warn",
      "derived_from": "Crisis Blindspot",
      "condition": {
        "metric": "customer.support_tickets",
        "operator": "gt",
        "threshold": 50
      },
      "reason": "High volume of support tickets may suggest product or service issues."
    },
    {
      "id": "GR-006",
      "name": "Optimal Product Template",
      "category": "product_launch",
      "severity": "warn",
      "derived_from": "Healthy SKU Signal",
      "condition": {
        "metric": "health_score",
        "operator": "eq",
        "threshold": "5/5"
      },
      "reason": "Product has optimal metrics across customer, ad, and sales."
    },
    {
      "id": "GR-007",
      "name": "High Refund Rate Indicator",
      "category": "customer_interaction",
      "severity": "block",
      "derived_from": "Crisis Blindspot",
      "condition": {
        "metric": "refund_rate",
        "operator": "gt",
        "threshold": 0.15
      },
      "reason": "High refund rate indicates customer dissatisfaction."
    },
    {
      "id": "GR-008",
      "name": "Positive NPS Alert",
      "category": "customer_interaction",
      "severity": "warn",
      "derived_from": "Healthy SKU Signal",
      "condition": {
        "metric": "customer.nps",
        "operator": "gt",
        "threshold": 70
      },
      "reason": "High NPS suggests strong customer satisfaction."
    },
    {
      "id": "GR-009",
      "name": "Social Reach Trigger",
      "category": "campaign_launch",
      "severity": "warn",
      "derived_from": "Healthy SKU Signal",
      "condition": {
        "metric": "social.reach",
        "operator": "gt",
        "threshold": 50000
      },
      "reason": "High social media reach is favorable for product exposure."
    },
    {
      "id": "GR-010",
      "name": "ROAS Mismatch Notification",
      "category": "campaign_launch",
      "severity": "warn",
      "derived_from": "ROAS Underclaim",
      "condition": {
        "metric": "platform_roas_to_true_roas_ratio",
        "operator": "lt",
        "threshold": 0.7
      },
      "reason": "Substantial discrepancy between platform ROAS and true ROAS."
    },
    {
      "id": "GR-011",
      "name": "Sentiment Mismatch Warning",
      "category": "customer_interaction",
      "severity": "block",
      "derived_from": "Crisis Blindspot",
      "condition": {
        "metric": "sentiment_mismatch",
        "operator": "gt",
        "threshold": 0.1
      },
      "reason": "Mismatch between customer sentiment and expected experience."
    },
    {
      "id": "GR-012",
      "name": "NPS Improvement Opportunity",
      "category": "customer_interaction",
      "severity": "warn",
      "derived_from": "Healthy SKU Signal",
      "condition": {
        "metric": "customer.nps",
        "operator": "lt",
        "threshold": 60
      },
      "reason": "NPS below desired level, indicating potential for improvement."
    }
  ]
}